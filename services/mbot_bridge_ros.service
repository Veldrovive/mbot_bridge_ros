[Unit]
Description=MBot ROS 2 Bridge Service
After=network.target

[Service]
Type=simple
User=mbot
# Adjust this path if you cloned the repository to a different location
ExecStart=/home/mbot/mbot_bridge_ros/services/start_bridge.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
